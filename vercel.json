{
  "crons": [
    {
      "path": "/api/cron-poll",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cape-counts?force=true",
      "schedule": "*/30 * * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/check-claim", "destination": "/api/claim" },
    { "source": "/api/start-claim", "destination": "/api/claim" }
  ]
}
